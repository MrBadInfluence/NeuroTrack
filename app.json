{
  "expo": {
    "name": "NeuroTrack",
    "slug": "NeuroTrack_RN",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "neurotrack",
    "newArchEnabled": true,
    "updates": {
      "enabled": false
    },
    "icon": "./assets/play_store_512.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/play_store_512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mrbadinfluence.NeuroTrack",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/NeuroTrackCANVAimage3.png"
    },
    "extra": {
      "eas": {
        "projectId": "d8e29d93-7cc7-48b1-8ad6-e6cc37fc6cf8"
      }
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/play_store_512.png",
          "color": "#FF9800",
          "defaultChannel": "medication-reminders",
          "sounds": []
        }
      ],
      "@react-native-google-signin/google-signin"
    ]
  }
}
